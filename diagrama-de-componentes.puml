@startuml diagrama-de-componentes
title Sistema de Gestão das Olimpíadas (SGO) - Diagrama de Componentes

skinparam componentStyle uml2

actor "Usuário" as user

package "Frontend" {
  [Interface de Usuário\n(Web/Mobile)] as UI
}

package "Backend - SGO" {

  [API Gateway] as API

  package "Módulos de Negócio" {
    [Módulo de Competições] as MComp
    [Módulo de Inscrições] as MInsc
    [Módulo de Alocação] as MAloc
    [Módulo de Resultados] as MRes
    [Módulo de Relatórios] as MRel
  }

  [Módulo de Autenticação] as MAut
  [Módulo de Notificações] as MNot
}

package "Persistência" {
  database "Banco de Dados\nRelacional" as DB
  database "Cache" as Cache
}

package "Serviços Externos" {
  [Serviço de E-mail] as Email
  [Serviço de Geração de PDF] as PDF
}

' Interfaces (lollipops)
UI -( API : HTTP/REST
API -( MAut : autentica
API -( MComp : /competicoes
API -( MInsc : /inscricoes
API -( MAloc : /alocacoes
API -( MRes : /resultados
API -( MRel : /relatorios

' Interações do usuário
user --> UI

' Dependências entre módulos
MComp ..> MAloc : valida local
MInsc ..> MComp : consulta competição
MAloc ..> MComp : aloca para
MRes ..> MComp : registra em
MRel ..> MRes : consolida
MRel ..> PDF : exporta

' Notificações
MInsc ..> MNot : notifica atleta
MRes ..> MNot : notifica resultado
MNot ..> Email : envia

' Persistência
MComp --> DB
MInsc --> DB
MAloc --> DB
MRes --> DB
MRel --> DB
MAut --> DB
MRel --> Cache

@enduml
