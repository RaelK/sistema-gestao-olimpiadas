@startuml diagrama-de-pacotes
title Sistema de Gestão das Olimpíadas (SGO) - Diagrama de Pacotes

skinparam packageStyle folder

package "sgo" {

  package "presentation" as apresentacao {
    package "web" {
      class CompeticaoController
      class AtletaController
      class LocalController
      class ResultadoController
      class RelatorioController
    }
    package "view" {
      class TelaCadastro
      class TelaInscricao
      class TelaRelatorio
    }
  }

  package "business" as negocio {
    package "service" {
      class CompeticaoService
      class InscricaoService
      class AlocacaoService
      class ResultadoService
      class RelatorioService
    }
    package "rules" {
      class ValidadorInscricao
      class ValidadorAlocacao
      class CalculadoraMedalhas
    }
  }

  package "domain" as dominio {
    class Atleta
    class Competicao
    class Local
    class Resultado
    class Pais
    class Medalha
    class Modalidade
    class Inscricao
  }

  package "persistence" as persistencia {
    package "repository" {
      class CompeticaoRepository
      class AtletaRepository
      class LocalRepository
      class ResultadoRepository
      class PaisRepository
    }
    package "database" {
      class ConexaoBD
    }
  }

  package "security" as seguranca {
    class AutenticacaoService
    class AutorizacaoService
    class Usuario
  }

  package "utils" as utilitarios {
    class DataUtils
    class FormatadorRelatorio
    class GeradorPDF
  }
}

' Dependências entre pacotes
apresentacao ..> negocio : usa
negocio ..> dominio : manipula
negocio ..> persistencia : persiste
persistencia ..> dominio : armazena
apresentacao ..> seguranca : autentica
negocio ..> seguranca : autoriza
negocio ..> utilitarios : utiliza
apresentacao ..> utilitarios : utiliza

@enduml
