@startuml diagrama-de-caso-de-uso
title Sistema de Gestão das Olimpíadas (SGO) - Diagrama de Casos de Uso

left to right direction

skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Administrador" as admin
actor "Organizador" as org
actor "Atleta" as atleta
actor "Juiz" as juiz
actor "Público" as publico

rectangle "Sistema de Gestão das Olimpíadas (SGO)" {

  usecase "Cadastrar Competição" as UC01
  usecase "Editar Competição" as UC02
  usecase "Cancelar Competição" as UC03
  usecase "Inscrever Atleta" as UC04
  usecase "Cadastrar Atleta" as UC05
  usecase "Validar Inscrição" as UC06
  usecase "Cadastrar Local" as UC07
  usecase "Alocar Local" as UC08
  usecase "Verificar Conflito de Horário" as UC09
  usecase "Registrar Resultado" as UC10
  usecase "Definir Pódio" as UC11
  usecase "Gerar Relatório de Medalhas" as UC12
  usecase "Consultar Ranking por País" as UC13
  usecase "Consultar Competições" as UC14
  usecase "Autenticar Usuário" as UC15
}

' Relações do Administrador
admin --> UC01
admin --> UC02
admin --> UC03
admin --> UC05
admin --> UC07
admin --> UC15

' Relações do Organizador
org --> UC01
org --> UC08
org --> UC06
org --> UC12
org --> UC15

' Relações do Atleta
atleta --> UC04
atleta --> UC14
atleta --> UC15

' Relações do Juiz
juiz --> UC10
juiz --> UC15

' Relações do Público
publico --> UC14
publico --> UC13

' Relações de inclusão e extensão
UC01 ..> UC08 : <<include>>
UC04 ..> UC06 : <<include>>
UC08 ..> UC09 : <<include>>
UC10 ..> UC11 : <<include>>
UC12 ..> UC11 : <<include>>
UC02 ..> UC01 : <<extend>>
UC03 ..> UC01 : <<extend>>

@enduml
