@startuml diagrama-de-implantacao
title Sistema de Gestão das Olimpíadas (SGO) - Diagrama de Implantação

skinparam node {
  BackgroundColor #F5F5F5
  BorderColor #333333
}

node "Dispositivo do Usuário\n<<desktop / mobile>>" as cliente {
  artifact "Navegador Web" as browser
  artifact "App Mobile" as mobile
}

cloud "Internet" as net

node "Servidor de Aplicação\n<<application server>>" as srvApp {
  artifact "API REST SGO\n(Spring Boot / Node.js)" as api
  artifact "Módulo de Autenticação" as auth
  artifact "Módulos de Negócio\n(Competições, Inscrições,\nAlocação, Resultados, Relatórios)" as modulos
}

node "Servidor Web\n<<web server>>" as srvWeb {
  artifact "Frontend SGO\n(React / Angular)" as front
  artifact "Nginx / Apache" as nginx
}

node "Servidor de Banco de Dados\n<<database server>>" as srvDB {
  database "PostgreSQL / MySQL" as bd {
    artifact "Esquema SGO\n(competicoes, atletas,\nlocais, resultados,\nmedalhas, paises)" as schema
  }
}

node "Servidor de Cache\n<<cache server>>" as srvCache {
  artifact "Redis" as redis
}

node "Servidor de Arquivos\n<<file server>>" as srvFile {
  artifact "Armazenamento\n(Relatórios PDF,\nImagens)" as files
}

cloud "Serviços Externos" as ext {
  node "Servidor de E-mail\n<<SMTP>>" as smtp {
    artifact "Serviço de E-mail" as mail
  }
}

' Conexões
browser --> net : HTTPS
mobile --> net : HTTPS
net --> nginx : HTTPS (443)
nginx --> front
nginx --> api : HTTP (proxy)
api --> auth
api --> modulos
modulos --> bd : JDBC / TCP (5432)
modulos --> redis : TCP (6379)
modulos --> files : NFS / S3
modulos --> mail : SMTP (587)

@enduml
